{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true, // Essencial para ignorar conflitos em libs externas

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    /* ⚠️ AJUSTE AQUI: Desativamos o verbatimModuleSyntax para maior compatibilidade */
    "verbatimModuleSyntax": false,

    /* ⚠️ ADIÇÃO: Garantir que ele olha para os tipos instalados */
    "typeRoots": ["./node_modules/@types"],

    "allowJs": false,
    "checkJs": false,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}